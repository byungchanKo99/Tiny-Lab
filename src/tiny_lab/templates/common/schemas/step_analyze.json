{
  "type": "object",
  "required": [
    "total_experiments",
    "wins",
    "losses",
    "best_experiment",
    "patterns"
  ],
  "properties": {
    "total_experiments": { "type": "integer" },
    "wins": { "type": "integer" },
    "losses": { "type": "integer" },
    "marginals": { "type": "integer" },
    "invalids": { "type": "integer" },
    "best_experiment": {
      "type": "object",
      "required": ["id", "metric_value", "approach"],
      "properties": {
        "id": { "type": "string" },
        "metric_value": { "type": "number" },
        "approach": { "type": "string" }
      }
    },
    "patterns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Observed patterns from experiment results"
    },
    "failure_patterns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Common failure patterns to avoid"
    },
    "domain_mismatch": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Approaches that don't fit the domain type"
    },
    "gap_analysis": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Literature techniques not yet tried"
    },
    "optimizer_efficiency": {
      "type": "object",
      "properties": {
        "underexplored": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Approaches with insufficient trials (approach name + trial count + time/trial)"
        },
        "time_budget_sufficient": {
          "type": "boolean",
          "description": "Whether current time_budget allows sufficient trials for all approaches"
        },
        "recommended_time_budget": {
          "type": ["integer", "null"],
          "description": "Recommended time_budget if current is insufficient, null if adequate"
        }
      }
    }
  }
}
