{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["score", "reasoning"],
  "properties": {
    "score": {
      "type": "number",
      "description": "Numeric score within the configured score_range"
    },
    "reasoning": {
      "type": "string",
      "description": "Brief explanation of the score"
    },
    "criteria_scores": {
      "type": "object",
      "additionalProperties": { "type": "number" },
      "description": "Per-criterion scores"
    },
    "strengths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "weaknesses": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
